# ====================== 7coder CONFIG ========================
# Required
OPENAI_API_KEY=sk-x

# Optional OpenAI-compatible endpoint (e.g. Groq, local LLM, etc.)
OPENAI_ENDPOINT=http://100.118.11.83:11434/v1

# Models - heavy for coding/computer tasks, light for moderation/risk
HEAVY_MODEL=sparksammy/samantha-combo:latest
LIGHT_MODEL=sparksammy/samantha-combo:lite
VISION_MODEL=sparksammy/samantha-combo:lite

# General
TEMPERATURE=0.6
MAX_TOKENS=42000
MAX_RETRIES=14
ENABLE_RALPH_MODE=false

# Permission & Security System
PERMISSION_MODE=default        # default | auto | bypass | denial

# Features
ENABLE_HTTP_SERVER=false       # Set true or use --server flag
HTTP_PORT=7103                 # clod haha funni
ENABLE_COMPUTER_USE=false      # Full cross-platform computer use
DREAM_ALLOW=false                 # Enable auto dream mode (self-consolidation of 7CODER.md after >=5h idle)
ENABLE_AUTO_DEBUG=true             # Enable automated app/script debug tool (launch + test + auto-fix loop)
DEBUG_TEST_MINUTES=3               # Default test duration for auto_debug_tool (2-5)
BICKER_ROUNDS=5                    # Max debate rounds for bickering_tool before forcing compromise

# MCP Server support (comma-separated; leave empty to disable)
MCP_SERVER_URLS=                  # e.g. http://localhost:8080,https://mcp.example.com
MCP_NPX_PKGS=                     # e.g. @modelcontextprotocol/server-filesystem,mcp-pkg-name

# Optional (for future MCP/custom extensions)
# MCP_SERVER_URL=
