# .env.example
# Copy this file to .env and fill in your values

# Required - your OpenAI (or compatible) API key. If not required, just put "x"
OPENAI_API_KEY=sk-your-key-here

# OpenAI-compatible endpoint (works with OpenAI, OpenRouter, Groq, local LM Studio, etc.)
OPENAI_ENDPOINT=http://192.168.50.60:11434/v1

# Set to "true" to enable "Claude-Like Ralph Wiggum" mode:
# a self-iteration feedback loop where the AI keeps refining its own code
# until it signals completion or hits max retries
ENABLE_CLAUDE_LIKE_RALPH_WIGGUM_MODE=false

# Completion settings
OPENAI_MODEL=qwen3.5:9b
TEMPERATURE=0.6
MAX_TOKENS=42000

# Max attempt retries (used for both API failures AND the Ralph Wiggum loop iterations)
MAX_ATTEMPT_RETRIES=7
